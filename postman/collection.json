{
  "info": {
    "_postman_id": "ba14b777-8f0b-4b8d-9d8d-lab140000001",
    "name": "Dorj — JSONPlaceholder API Testing",
    "description": "Lab 14 Integration & API Testing collection using JSONPlaceholder public API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "Happy GET - List posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Get all posts and validate list response."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response time below 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "const data = pm.response.json();",
                  "pm.test('Response is array', () => pm.expect(data).to.be.an('array'));",
                  "pm.test('List has posts', () => pm.expect(data.length).to.be.above(0));",
                  "pm.test('First post has required properties', () => { pm.expect(data[0]).to.have.property('id'); pm.expect(data[0]).to.have.property('title'); pm.expect(data[0]).to.have.property('body'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET by id - Post 1",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1"]
            },
            "description": "Get one post by id and validate schema and business values."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "pm.test('Post has id 1', () => pm.expect(d.id).to.eql(1));",
                  "pm.test('userId is number', () => pm.expect(d.userId).to.be.a('number'));",
                  "pm.test('title is non-empty string', () => pm.expect(d.title).to.be.a('string').and.not.empty);",
                  "pm.test('body is non-empty string', () => pm.expect(d.body).to.be.a('string').and.not.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST create - Create post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{randomTitle}}\",\n  \"body\": \"{{randomBody}}\",\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Create a post, validate 201 response, and save returned id for chained request."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const suffix = Date.now();",
                  "pm.environment.set('randomTitle', `Lab14 title ${suffix}`);",
                  "pm.environment.set('randomBody', `Generated body for API testing ${suffix}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json();",
                  "pm.environment.set('createdPostId', d.id);",
                  "pm.test('Created response has id', () => pm.expect(d).to.have.property('id'));",
                  "pm.test('Created id is number', () => pm.expect(d.id).to.be.a('number'));",
                  "pm.test('Title matches request variable', () => pm.expect(d.title).to.eql(pm.environment.get('randomTitle')));",
                  "pm.test('Business rule userId is 1', () => pm.expect(d.userId).to.eql(1));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Chained GET - Created post id expected not persisted",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{createdPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{createdPostId}}"]
            },
            "description": "Use createdPostId from POST response; JSONPlaceholder does not persist created resources, so 404 is expected."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('createdPostId variable exists', () => pm.expect(pm.environment.get('createdPostId')).to.not.be.undefined);",
                  "pm.test('Status 404 because fake API does not persist POST data', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "PUT update - Update post 1",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"title\": \"Updated title from Lab14\",\n  \"body\": \"Updated body from Newman and Postman\",\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1"]
            },
            "description": "Update a post using PUT and validate changed fields."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "pm.test('Updated id remains 1', () => pm.expect(d.id).to.eql(1));",
                  "pm.test('Updated title is correct', () => pm.expect(d.title).to.eql('Updated title from Lab14'));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "PATCH update - Partial update post 1",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Partially updated title\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1"]
            },
            "description": "Partially update a post title using PATCH."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "pm.test('Patched title is correct', () => pm.expect(d.title).to.eql('Partially updated title'));",
                  "pm.test('Response still has body property', () => pm.expect(d).to.have.property('body'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "DELETE - Delete post 1",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1"]
            },
            "description": "Delete a post and validate successful delete response."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Delete response body is empty object', () => pm.expect(pm.response.json()).to.be.an('object'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Errors",
      "item": [
        {
          "name": "Error case - GET missing post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/999999",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "999999"]
            },
            "description": "Negative test: request a non-existing post and expect 404."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Response time below 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ]
}
